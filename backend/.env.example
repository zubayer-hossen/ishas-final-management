# ==============================
# SERVER
# ==============================
NODE_ENV=development
PORT=5000
# One origin, or a comma-separated list for supporting multiple frontends
# (e.g. local dev + deployed Netlify URL). The FIRST url in the list is
# also used to build links inside emails, PDF receipts, and QR codes —
# put your main production frontend URL first.
# CLIENT_URL=https://yourapp.netlify.app,http://localhost:5173
CLIENT_URL=http://localhost:5173

# ==============================
# DATABASE
# ==============================
MONGO_URI=mongodb://127.0.0.1:27017/ishas_organization

# ==============================
# JWT
# ==============================
JWT_ACCESS_SECRET=change_this_access_secret_to_a_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_to_a_long_random_string
JWT_REFRESH_EXPIRES=30d

# ==============================
# COOKIE
# ==============================
COOKIE_SECRET=change_this_cookie_secret

# ==============================
# EMAIL (Nodemailer - Gmail SMTP example)
# ==============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM_NAME=ISHAS Organization
EMAIL_FROM_ADDRESS=your_email@gmail.com

# ==============================
# OTP
# ==============================
OTP_EXPIRES_MINUTES=10

# ==============================
# CLOUDINARY
# ==============================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==============================
# RATE LIMIT
# ==============================
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=500

# ==============================
# FIRST OWNER SEED (used only by `npm run seed`)
# ==============================
OWNER_NAME=System Owner
OWNER_EMAIL=owner@ishas.org
OWNER_PASSWORD=ChangeMe@12345
