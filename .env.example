# Used by docker-compose.yml — copy this to .env in the project root
# before running `docker compose up`. These values are injected into
# the backend container's environment.

JWT_ACCESS_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_string
COOKIE_SECRET=change_this_cookie_secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM_NAME=ISHAS Organization
EMAIL_FROM_ADDRESS=your_email@gmail.com

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

OWNER_NAME=System Owner
OWNER_EMAIL=owner@ishas.org
OWNER_PASSWORD=ChangeMe@12345
